{
  "name": "@nisli/ssg",
  "version": "0.1.0",
  "description": "Static site generation tooling for Nisli publications.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gkoreli/nisli.git",
    "directory": "packages/ssg"
  },
  "keywords": [
    "ssg",
    "static-site-generator",
    "nisli",
    "web-components",
    "publication"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  }
}
